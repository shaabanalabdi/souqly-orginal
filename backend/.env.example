# backend/.env
DATABASE_URL=mysql://root:password@localhost:3306/souqly
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-random-256-bit-secret
REFRESH_TOKEN_SECRET=change-me-to-another-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OAUTH_MOCK_MODE=true
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=souqly-media
S3_CDN_URL=https://cdn.souqly.com
S3_REGION=fsn1
RESEND_API_KEY=
EMAIL_FROM=noreply@souqly.com
FRONTEND_URL=http://localhost:5173
SAVED_SEARCH_DIGEST_ENABLED=true
SAVED_SEARCH_DIGEST_CHECK_MS=3600000
SAVED_SEARCH_DIGEST_HISTORY_MAX_ITEMS=250
ANTI_FRAUD_ENABLED=true
ANTI_FRAUD_LOW_PRICE_RATIO=0.25
ANTI_FRAUD_HIGH_PRICE_RATIO=4
ANTI_FRAUD_NEW_ACCOUNT_DAYS=7
ANTI_FRAUD_HIGH_VALUE_THRESHOLD=5000
NODE_ENV=development
PORT=5000
